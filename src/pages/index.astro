---
import "../style.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Priyansh Agrahari</title>
    <meta name="description" content="Priyansh Agrahari's website" />
  </head>
  <body>
    <header>
      <h1>Hi, I'm Priyansh Agrahari :)</h1>
      <Navigation />
    </header>

    <main>
      <p>
        Welcome to my site! I love cats 😸, nature 🌲, and making fun stuff.
      </p>
    </main>

    <Footer />

    <script is:inline type="module">
      import { Neko } from "https://cdn.jsdelivr.net/npm/neko-ts@0.0.7/dist/neko-ts.min.js";
      document.addEventListener("DOMContentLoaded", () => {
        new Neko({ parent: document.documentElement });
      });
    </script>
  </body>
</html>
